<?xml version="1.0"?>
<ruleset name="FoldSnapPluginCheck">

    <arg name="extensions" value="php"/>

    <exclude-pattern>/.git/*</exclude-pattern>
    <exclude-pattern>*/node_modules/*</exclude-pattern>
    <exclude-pattern>/tools/*</exclude-pattern>
    <exclude-pattern>/assets/*</exclude-pattern>
    <exclude-pattern>/vendor/*</exclude-pattern>
    <exclude-pattern>/tests/*</exclude-pattern>

    <description>WordPress.org plugin compliance checks for FoldSnap.</description>

    <!-- PHP 7.4+ compatibility (WordPress-aware, avoids false positives on WP polyfills) -->
    <config name="testVersion" value="7.4-"/>
    <rule ref="PHPCompatibilityWP"/>

    <!-- WordPress security, DB, code analysis, and WP-specific rules only -->
    <rule ref="WordPress.Security"/>
    <rule ref="WordPress.DB"/>
    <rule ref="WordPress.CodeAnalysis"/>
    <rule ref="WordPress.WP"/>

    <!-- Plugin-prefix checks (matches WP.org Plugin Check) -->
    <rule ref="WordPress.NamingConventions.PrefixAllGlobals">
        <properties>
            <property name="prefixes" type="array">
                <element value="foldsnap"/>
                <element value="FoldSnap"/>
                <element value="FOLDSNAP"/>
            </property>
        </properties>
    </rule>
    <rule ref="WordPress.DateTime"/>
    <rule ref="WordPress.PHP.DevelopmentFunctions"/>
    <rule ref="WordPress.PHP.DiscouragedPHPFunctions"/>
    <rule ref="WordPress.PHP.DontExtract"/>
    <rule ref="WordPress.PHP.IniSet"/>
    <rule ref="WordPress.PHP.NoSilencedErrors"/>
    <rule ref="WordPress.PHP.PregQuoteDelimiter"/>
    <rule ref="WordPress.PHP.RestrictedPHPFunctions"/>
    <rule ref="WordPress.PHP.StrictInArray"/>
    <rule ref="WordPress.PHP.TypeCasts"/>
    <rule ref="WordPress.PHP.YodaConditions"/>

    <!-- I18n with correct text domain -->
    <rule ref="WordPress.WP.I18n">
        <properties>
            <property name="text_domain" type="array">
                <element value="foldsnap"/>
            </property>
        </properties>
    </rule>

    <!-- Forbidden dangerous functions -->
    <rule ref="Generic.PHP.ForbiddenFunctions">
        <properties>
            <property name="forbiddenFunctions" type="array">
                <element key="eval" value="null"/>
                <element key="create_function" value="null"/>
                <element key="passthru" value="null"/>
                <element key="proc_open" value="null"/>
                <element key="popen" value="null"/>
                <element key="move_uploaded_file" value="null"/>
                <element key="str_rot13" value="null"/>
            </property>
        </properties>
    </rule>

    <!-- PHP safety -->
    <rule ref="Generic.PHP.BacktickOperator"/>
    <rule ref="Generic.PHP.DiscourageGoto">
        <type>error</type>
    </rule>
    <rule ref="Generic.PHP.DisallowShortOpenTag"/>
    <rule ref="Generic.PHP.DisallowAlternativePHPTags"/>

    <!-- BOM not allowed: prevents headers-already-sent issues -->
    <rule ref="Generic.Files.ByteOrderMark"/>

    <!-- Functions discouraged on WP.org for hosting/runtime safety -->
    <rule ref="Squiz.PHP.DiscouragedFunctions">
        <properties>
            <property name="forbiddenFunctions" type="array">
                <element key="set_time_limit" value="null"/>
                <element key="ini_set" value="null"/>
                <element key="ini_alter" value="null"/>
                <element key="dl" value="null"/>
            </property>
        </properties>
    </rule>

</ruleset>
